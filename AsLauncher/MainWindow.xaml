<Window x:Class="AsLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lang="clr-namespace:AsLauncher.Resources.Localization"
        Title="AsLauncher"
        Icon="Assets/Icons/App/AsLauncher.ico"
        Width="1280"
        Height="720"
        MinWidth="854"
        MinHeight="480"
        WindowStartupLocation="CenterScreen"
        Background="#111111"
        FontFamily="Segoe UI">

    <Window.Resources>

        <!-- Sidebar Button Style -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button">

            <Setter Property="Background" Value="#181818"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="16,0,16,0"/>
            <Setter Property="Margin" Value="0,0,0,10"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12">

                            <ContentPresenter x:Name="ButtonContent"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              Margin="0,0,0,2"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">

                                <Setter TargetName="Border"
                                        Property="Background"
                                        Value="#252525"/>

                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">

                                <Setter TargetName="Border"
                                        Property="Background"
                                        Value="#303030"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

    </Window.Resources>

    <Grid>

        <Grid.ColumnDefinitions>

            <ColumnDefinition x:Name="SidebarColumn" Width="240"/>

            <ColumnDefinition Width="*"/>

        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#181818">

            <StackPanel Margin="20">

                <Button x:Name="SidebarToggleButton"
                        Width="32"
                        Height="32"
                        HorizontalAlignment="Right"
                        Margin="0,0,0,20"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        FocusVisualStyle="{x:Null}"
                        Click="SidebarToggleButton_Click">

                    <Button.Template>

                        <ControlTemplate TargetType="Button">

                            <Border x:Name="ButtonBorder"
                                    Background="Transparent"
                                    Opacity="1">

                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>

                            </Border>

                            <ControlTemplate.Triggers>

                                <Trigger Property="IsMouseOver" Value="True">

                                    <Setter TargetName="ButtonBorder"
                                            Property="Opacity"
                                            Value="0.8"/>

                                </Trigger>

                            </ControlTemplate.Triggers>

                        </ControlTemplate>

                    </Button.Template>

                    <Image x:Name="SidebarToggleIcon"
                           Width="18"
                           Height="18"
                           Source="Assets/Buttons/Sidebar/ExpandButton.png"
                           RenderTransformOrigin="0.5,0.5">

                        <Image.RenderTransform>

                            <RotateTransform Angle="0"/>

                        </Image.RenderTransform>

                    </Image>

                </Button>

                <!--- Sidebar Title -->
                <TextBlock x:Name="SidebarTitle"
                               Text="AsLauncher"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Margin="0,10,0,40"/>

                <!--- Sidebar Buttons -->
                <!-- General -->
                <Button x:Name="GeneralButton"
                        Click="GeneralButton_Click"
                        Style="{StaticResource SidebarButtonStyle}">

                    <StackPanel x:Name="GeneralStackPanel" Orientation="Horizontal">

                        <Image Source="Assets/Icons/Sidebar/IconGeneral.png"
                               Width="22"
                               Height="22"
                               Margin="10,0,12,0"
                               VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               SnapsToDevicePixels="True"
                               UseLayoutRounding="True"/>

                        <TextBlock x:Name="NavGeneralText"
                                   Text="{x:Static lang:Resources.MainLabelsGeneral}"
                                   VerticalAlignment="Center"/>

                    </StackPanel>

                </Button>

                <!-- Vanilla -->
                <Button x:Name="VanillaButton"
                        Click="VanillaButton_Click"
                        Style="{StaticResource SidebarButtonStyle}">

                    <StackPanel x:Name="VanillaStackPanel" Orientation="Horizontal">

                        <Image Source="Assets/Icons/Sidebar/IconVanilla.png"
                               Width="22"
                               Height="22"
                               Margin="10,0,12,0"
                               VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               SnapsToDevicePixels="True"
                               UseLayoutRounding="True"/>

                        <TextBlock x:Name="NavVanillaText"
                                   Text="{x:Static lang:Resources.MainLabelsVanilla}"
                                   VerticalAlignment="Center"/>

                    </StackPanel>

                </Button>

                <!-- Modpacks -->
                <Button x:Name="ModpacksButton"
                        Click="ModpacksButton_Click"
                        Style="{StaticResource SidebarButtonStyle}">

                    <StackPanel x:Name="ModpacksStackPanel" Orientation="Horizontal">

                        <Image Source="Assets/Icons/Sidebar/IconModpacks.png"
                               Width="22"
                               Height="22"
                               Margin="10,0,12,0"
                               VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               SnapsToDevicePixels="True"
                               UseLayoutRounding="True"/>

                        <TextBlock x:Name="NavModpacksText"
                                   Text="{x:Static lang:Resources.MainLabelsModpacks}"
                                   VerticalAlignment="Center"/>

                    </StackPanel>

                </Button>

                <!-- Configs -->
                <Button x:Name="ConfigsButton"
                        Click="ConfigsButton_Click"
                        Style="{StaticResource SidebarButtonStyle}">

                    <StackPanel x:Name="ConfigsStackPanel" Orientation="Horizontal">

                        <Image Source="Assets/Icons/Sidebar/IconConfigs.png"
                               Width="22"
                               Height="22"
                               Margin="10,0,12,0"
                               VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               SnapsToDevicePixels="True"
                               UseLayoutRounding="True"/>

                        <TextBlock x:Name="NavConfigsText"
                                   Text="{x:Static lang:Resources.MainLabelsConfigs}"
                                   VerticalAlignment="Center"/>

                    </StackPanel>

                </Button>

            </StackPanel>

        </Border>

        <!-- Main Content -->
        <ContentControl x:Name="MainContent" Grid.Column="1"/>

    </Grid>

</Window>