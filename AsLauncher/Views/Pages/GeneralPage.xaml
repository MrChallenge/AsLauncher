<UserControl x:Class="AsLauncher.Views.Pages.GeneralPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lang="clr-namespace:AsLauncher.Resources.Localization"
             xmlns:core="clr-namespace:AsLauncher.Core"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AsLauncher.Views.Pages"
             mc:Ignorable="d" 
             d:DesignHeight="450"
             d:DesignWidth="800">
    
    <Grid>

        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MaxWidth="700">

            <Image Source="{x:Static core:Theme.LauncherLogo}"
                   Width="96"
                   Height="96"
                   Margin="0,0,0,20"/>

            <TextBlock Text="AsLauncher"
                       Foreground="{x:Static core:Theme.White}"
                       FontSize="42"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,25"/>

            <TextBlock Text="{x:Static lang:Resources.PagespaceGeneralDesc}"
                       Foreground="{x:Static core:Theme.LightGrey}"
                       FontSize="16"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       LineHeight="24"/>

        </StackPanel>

    </Grid>
    
</UserControl>
